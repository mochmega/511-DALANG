# Wajib diisi — app akan crash kalau kosong
JWT_SECRET_KEY=ganti_dengan_string_panjang_random_minimal_32_karakter

# Database — default SQLite jika tidak diisi
SQLALCHEMY_DATABASE_URI=sqlite:///gudang.db

# Kredensial admin pertama — hanya diproses saat init_db()
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ganti_password_kuat_disini

# JWT expiry dalam detik — default 8 jam (28800)
JWT_ACCESS_TOKEN_EXPIRES=28800

# CORS — pisahkan dengan koma jika lebih dari satu origin
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
